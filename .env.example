# =============================================
# 数据库
# =============================================
# 开发环境用 SQLite
DATABASE_URL="file:./dev.db"
# 生产环境切换为 PostgreSQL：
# DATABASE_URL="postgresql://user:password@host:5432/blog"

# =============================================
# NextAuth.js 认证
# =============================================
# 生成方法：openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# 管理员密码（明文，NextAuth 会自动与 bcrypt 比较）
ADMIN_PASSWORD="your-strong-admin-password"
ADMIN_EMAIL="admin@yourdomain.com"

# =============================================
# Stripe 支付
# =============================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Stripe CLI 本地测试：stripe listen --forward-to localhost:3000/api/payments/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================
# 邮件发送（Nodemailer，使用 Gmail 示例）
# =============================================
EMAIL_FROM="yourblog@gmail.com"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="yourblog@gmail.com"
EMAIL_PASS="your-app-password"

# =============================================
# 网站配置
# =============================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="我的小站"

# =============================================
# Cloudflare R2 存储
# =============================================
# 1. 登录 Cloudflare Dashboard → R2 → 创建 Bucket
# 2. R2 → 概述 → Account ID 即为下方 R2_ACCOUNT_ID
# 3. R2 → 管理 API 令牌 → 创建令牌（编辑权限）
# 4. 在 Bucket 设置中开启"公开访问"或绑定自定义域名

R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="blog-media"
# 公开访问 URL，格式为 https://pub-xxx.r2.dev 或你绑定的自定义域名
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# =============================================
# 向日葵功能
# =============================================
# IP 哈希盐值（任意随机字符串，保护访客隐私）
# 生成方法：openssl rand -base64 24
SUNFLOWER_IP_SALT="change-this-to-a-random-string"

# ── 设置加密密钥（生产必填）──────────────────────────────────────────
# 用于加密存储 Stripe 密钥等敏感设置
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=your-64-hex-chars-here

# ── 管理员密码 Hash（可选，替代明文 ADMIN_PASSWORD）────────────────
# 生成方式: node -e "const b=require('bcryptjs');b.hash('yourpw',12).then(console.log)"
# ADMIN_PASSWORD_HASH=\$2b\$12\$...
